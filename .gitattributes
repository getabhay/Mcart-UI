* text=auto

# Keep text files normalized as LF in repo/working tree
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.sh text eol=lf

# Keep Windows scripts in CRLF for native execution expectations
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
